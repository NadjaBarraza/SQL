-- =====================================================
-- Chinook SQL Analysis Project
-- Dataset: Chinook Digital Media Store
-- Tools: SQL (SQLite)
--
-- This project explores customer, sales, and music data
-- from the Chinook database. The analysis covers customer
-- and invoice behavior, sales agent performance, track and
-- artist purchases, playlist composition, genre popularity,
-- and advanced SQL techniques including CTEs and window
-- functions.
--
-- Techniques used:
-- JOINs, GROUP BY, HAVING, aggregation functions,
-- CTEs, window functions, and ranking functions.
-- =====================================================


-- =====================================================
-- SECTION 1: BUSINESS AND SALES INSIGHTS
-- =====================================================

-- 1. Show the invoice total, customer name, customer country, and sales agent name for all invoices.
SELECT
    invoices.Total,
    customers.FirstName || ' ' || customers.LastName AS customer_name,
    customers.Country,
    employees.FirstName || ' ' || employees.LastName AS sales_agent_name
FROM customers
JOIN employees
    ON customers.SupportRepId = employees.EmployeeId
JOIN invoices
    ON customers.CustomerId = invoices.CustomerId
ORDER BY customer_name, invoices.InvoiceId;


-- 2. Show the total sales made by each sales agent.
SELECT
    employees.FirstName || ' ' || employees.LastName AS sales_agent_name,
    ROUND(SUM(invoices.Total), 2) AS total_sales
FROM employees
JOIN customers
    ON employees.EmployeeId = customers.SupportRepId
JOIN invoices
    ON customers.CustomerId = invoices.CustomerId
GROUP BY sales_agent_name
ORDER BY total_sales DESC;


-- 3. Which sales agent made the most dollars in sales in 2009?
SELECT
    employees.FirstName || ' ' || employees.LastName AS sales_agent_name,
    ROUND(SUM(invoices.Total), 2) AS total_sales
FROM employees
JOIN customers
    ON employees.EmployeeId = customers.SupportRepId
JOIN invoices
    ON customers.CustomerId = invoices.CustomerId
WHERE invoices.InvoiceDate LIKE '2009%'
GROUP BY sales_agent_name
ORDER BY total_sales DESC
LIMIT 1;


-- 4. How many invoices were there in 2009?
SELECT
    COUNT(invoices.InvoiceId) AS total_invoices_2009
FROM invoices
WHERE invoices.InvoiceDate LIKE '2009%';


-- 5. What were the total sales in 2009?
SELECT
    ROUND(SUM(invoices.Total), 2) AS total_sales_2009
FROM invoices
WHERE invoices.InvoiceDate LIKE '2009%';


-- 6. Provide a query that shows the invoices associated with each sales agent.
SELECT
    employees.FirstName || ' ' || employees.LastName AS sales_agent_name,
    COUNT(invoices.InvoiceId) AS total_invoices
FROM employees
JOIN customers
    ON employees.EmployeeId = customers.SupportRepId
JOIN invoices
    ON customers.CustomerId = invoices.CustomerId
GROUP BY sales_agent_name
ORDER BY total_invoices DESC, sales_agent_name;


-- 7. Show customers who are not in the US.
SELECT
    customers.FirstName || ' ' || customers.LastName AS full_name,
    customers.CustomerId,
    customers.Country
FROM customers
WHERE customers.Country <> 'USA'
ORDER BY full_name;


-- 8. Show only the customers from Brazil.
SELECT
    customers.FirstName || ' ' || customers.LastName AS full_name,
    customers.CustomerId,
    customers.Country
FROM customers
WHERE customers.Country = 'Brazil'
ORDER BY full_name;


-- 9. Show the invoices of customers who are from France.
SELECT
    customers.FirstName || ' ' || customers.LastName AS full_name,
    invoices.InvoiceId,
    invoices.InvoiceDate,
    invoices.BillingCountry
FROM customers
JOIN invoices
    ON customers.CustomerId = invoices.CustomerId
WHERE customers.Country = 'France'
ORDER BY full_name, invoices.InvoiceDate;


-- 10. Show the employees who are Sales Support Agents.
SELECT
    employees.FirstName || ' ' || employees.LastName AS full_name,
    employees.Title
FROM employees
WHERE employees.Title = 'Sales Support Agent'
ORDER BY full_name;


-- 11. Find a distinct list of billing countries from the invoices table.
SELECT DISTINCT
    invoices.BillingCountry
FROM invoices
ORDER BY invoices.BillingCountry;


-- =====================================================
-- SECTION 2: TRACK, ARTIST, AND MUSIC RELATIONSHIPS
-- =====================================================

-- 12. Show the purchased track name with each invoice line ID.
SELECT
    tracks.Name AS track_name,
    invoice_items.InvoiceLineId
FROM tracks
JOIN invoice_items
    ON tracks.TrackId = invoice_items.TrackId
ORDER BY track_name;


-- 13. Show the purchased track name and artist name with each invoice line ID.
SELECT
    tracks.Name AS track_name,
    artists.Name AS artist_name,
    invoice_items.InvoiceLineId
FROM tracks
JOIN invoice_items
    ON tracks.TrackId = invoice_items.TrackId
JOIN albums
    ON tracks.AlbumId = albums.AlbumId
JOIN artists
    ON albums.ArtistId = artists.ArtistId
ORDER BY artist_name, track_name;


-- 14. Show all tracks, including the album name, media type, and genre.
SELECT
    tracks.Name AS track_name,
    albums.Title AS album,
    media_types.Name AS media_type,
    genres.Name AS genre
FROM tracks
JOIN albums
    ON tracks.AlbumId = albums.AlbumId
JOIN media_types
    ON media_types.MediaTypeId = tracks.MediaTypeId
JOIN genres
    ON tracks.GenreId = genres.GenreId
ORDER BY genre, album, track_name;


-- =====================================================
-- SECTION 3: MUSIC AND PLAYLIST INSIGHTS
-- =====================================================

-- 15. What genres are most popular based on purchase quantity?
SELECT
    genres.Name AS genre_name,
    SUM(invoice_items.Quantity) AS total_purchases
FROM invoice_items
JOIN tracks
    ON invoice_items.TrackId = tracks.TrackId
JOIN genres
    ON genres.GenreId = tracks.GenreId
GROUP BY genres.Name
ORDER BY total_purchases DESC, genre_name;


-- 16. Which artists dominate the most popular genres?
WITH top_genres_cte AS (
    SELECT
        genres.GenreId,
        genres.Name AS genre_name,
        SUM(invoice_items.Quantity) AS total_sold
    FROM invoice_items
    JOIN tracks
        ON invoice_items.TrackId = tracks.TrackId
    JOIN genres
        ON genres.GenreId = tracks.GenreId
    GROUP BY genres.GenreId, genres.Name
    ORDER BY total_sold DESC
    LIMIT 3
)
SELECT
    top_genres_cte.genre_name,
    artists.Name AS artist_name,
    SUM(invoice_items.Quantity) AS artist_genre_purchases
FROM top_genres_cte
JOIN tracks
    ON top_genres_cte.GenreId = tracks.GenreId
JOIN invoice_items
    ON tracks.TrackId = invoice_items.TrackId
JOIN albums
    ON tracks.AlbumId = albums.AlbumId
JOIN artists
    ON albums.ArtistId = artists.ArtistId
GROUP BY top_genres_cte.genre_name, artists.Name
ORDER BY top_genres_cte.genre_name, artist_genre_purchases DESC, artist_name;


-- 17. Which tracks appear in the most playlists?
SELECT
    tracks.Name AS track_name,
    COUNT(playlist_track.TrackId) AS playlist_count
FROM playlist_track
JOIN tracks
    ON playlist_track.TrackId = tracks.TrackId
GROUP BY tracks.TrackId, tracks.Name
ORDER BY playlist_count DESC, track_name;


-- 18. Which genres are most represented in playlists?
SELECT
    genres.Name AS genre_name,
    COUNT(playlist_track.PlaylistId) AS appearances
FROM playlist_track
JOIN tracks
    ON playlist_track.TrackId = tracks.TrackId
JOIN genres
    ON tracks.GenreId = genres.GenreId
GROUP BY genres.Name
ORDER BY appearances DESC, genre_name;


-- 19. Which playlists have the most artist diversity?
SELECT
    playlists.Name AS playlist_name,
    COUNT(DISTINCT artists.ArtistId) AS distinct_artists
FROM playlist_track
JOIN tracks
    ON playlist_track.TrackId = tracks.TrackId
JOIN albums
    ON tracks.AlbumId = albums.AlbumId
JOIN artists
    ON artists.ArtistId = albums.ArtistId
JOIN playlists
    ON playlists.PlaylistId = playlist_track.PlaylistId
GROUP BY playlists.Name
ORDER BY distinct_artists DESC, playlist_name;


-- 20. What is the average track length by genre (in minutes)?
SELECT
    genres.Name AS genre_name,
    ROUND(AVG(tracks.Milliseconds) / 60000.0, 2) AS avg_duration_minutes
FROM tracks
JOIN genres
    ON tracks.GenreId = genres.GenreId
GROUP BY genres.Name
ORDER BY avg_duration_minutes DESC, genre_name;


-- 21. Which artists have the most tracks in the database?
SELECT
    artists.Name AS artist_name,
    COUNT(tracks.TrackId) AS track_count
FROM tracks
JOIN albums
    ON tracks.AlbumId = albums.AlbumId
JOIN artists
    ON albums.ArtistId = artists.ArtistId
GROUP BY artists.Name
ORDER BY track_count DESC, artist_name;


-- 22. Who are the top customers for the most popular genre?
WITH top_genre_cte AS (
    SELECT
        genres.GenreId,
        genres.Name AS genre_name,
        SUM(invoice_items.Quantity) AS total_sold
    FROM invoice_items
    JOIN tracks
        ON invoice_items.TrackId = tracks.TrackId
    JOIN genres
        ON genres.GenreId = tracks.GenreId
    GROUP BY genres.GenreId, genres.Name
    ORDER BY total_sold DESC
    LIMIT 1
)
SELECT
    customers.FirstName || ' ' || customers.LastName AS customer_name,
    top_genre_cte.genre_name,
    SUM(invoice_items.Quantity) AS total_genre_purchases
FROM top_genre_cte
JOIN tracks
    ON top_genre_cte.GenreId = tracks.GenreId
JOIN invoice_items
    ON tracks.TrackId = invoice_items.TrackId
JOIN invoices
    ON invoice_items.InvoiceId = invoices.InvoiceId
JOIN customers
    ON invoices.CustomerId = customers.CustomerId
GROUP BY customer_name, top_genre_cte.genre_name
ORDER BY total_genre_purchases DESC, customer_name;


-- =====================================================
-- SECTION 4: ADVANCED SQL (CTEs + WINDOW FUNCTIONS)
-- =====================================================

-- 23. Show each customer, each invoice total, and that customer’s average invoice total.
SELECT
    customers.FirstName || ' ' || customers.LastName AS full_name,
    invoices.InvoiceId,
    invoices.Total,
    ROUND(AVG(invoices.Total) OVER (PARTITION BY customers.CustomerId), 2) AS avg_invoice_total
FROM invoices
JOIN customers
    ON invoices.CustomerId = customers.CustomerId
ORDER BY full_name, invoices.InvoiceId;


-- 24. Rank tracks within each genre by purchase volume.
WITH track_sales_cte AS (
    SELECT
        genres.Name AS genre_name,
        tracks.Name AS track_name,
        SUM(invoice_items.Quantity) AS total_purchases
    FROM invoice_items
    JOIN tracks
        ON invoice_items.TrackId = tracks.TrackId
    JOIN genres
        ON tracks.GenreId = genres.GenreId
    GROUP BY genres.Name, tracks.Name
)
SELECT
    genre_name,
    track_name,
    total_purchases,
    DENSE_RANK() OVER (PARTITION BY genre_name ORDER BY total_purchases DESC) AS genre_rank
FROM track_sales_cte
ORDER BY genre_name, genre_rank, track_name;
